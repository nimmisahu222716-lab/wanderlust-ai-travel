<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <div class="card shadow-lg border-0 p-5 mb-5 host-profile-card">

        <div class="d-flex align-items-center">

            <% if(host.image && host.image.url){ %>

                <img
                    src="<%= host.image.url %>"
                     class="rounded-circle me-4 host-profile-image"
    width="150"
    height="150"
                    style="object-fit: cover;">

            <% } else { %>

                <div
                    class="rounded-circle bg-secondary d-flex justify-content-center align-items-center me-4"
                    style="width:150px;height:150px;">

                    <i class="fa-solid fa-user text-white fs-1"></i>

                </div>

            <% } %>

            <div>

                <h2 class="fw-bold mb-2">
                    <%= host.name || host.username %>
                </h2>

                <% if(host.location){ %>

                    <p class="text-muted mb-1">
                     <i class="fa-solid fa-location-dot text-danger me-2"></i> <%= host.location %>
                    </p>

                <% } %>
<% if(host.createdAt){ %>

<p class="text-muted">

    <i class="fa-solid fa-calendar-days text-primary me-2"></i>

    Member since

    <%= host.createdAt.toLocaleDateString("en-IN",{

        month:"long",

        year:"numeric"

    }) %>

</p>

<% } %>

                <h5>

    <i class="fa-solid fa-house text-success me-2"></i>

    <%= listingCount %> Listings

</h5>

            </div>

        </div>

        <% if(host.bio){ %>

            <hr>

            <h4>About</h4>

            <p>
                <%= host.bio %>
            </p>

        <% } %>

    </div>

    <h3 class="mb-4">
        Hosted Properties
    </h3>

    <div class="row">

        <% listings.forEach(listing => { %>

            <div class="col-md-4 mb-4">

                <div class="card h-100 shadow-sm">

                    <img
                        src="<%= listing.image.url %>"
                        class="card-img-top"
                        style="height:220px;object-fit:cover;">

                    <div class="card-body">

                        <h5>
                            <%= listing.title %>
                        </h5>

                        <p>
                            ₹<%= listing.price %> / night
                        </p>

                        <a
                            href="/listings/<%= listing._id %>"
                            class="btn btn-dark">

                            View Property

                        </a>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>