      <div class="navbar-nav">

    <a class="nav-link" href="/listings">
        Explore
    </a>

    <li class="nav-item dropdown">
    <a
        class="nav-link dropdown-toggle"
        href="#"
        id="aiDropdown"
        role="button"
        data-bs-toggle="dropdown"
        aria-expanded="false">

        <i class="fa-solid fa-robot me-1"></i>
        AI
    </a>

    <ul class="dropdown-menu shadow" aria-labelledby="aiDropdown">

        <li>
            <a class="dropdown-item" href="/trip-planner">
                <i class="fa-solid fa-route me-2"></i>
                Travel Planner
            </a>
        </li>

        <li>
            <a class="dropdown-item" href="/ai-assistant">
                <i class="fa-solid fa-comments me-2"></i>
                Travel Assistant
            </a>
        </li>

    </ul>
</li>

<li class="nav-item">
    <a class="nav-link" href="/wishlist">
        ❤️ Wishlist
    </a>
</li>

<li class="nav-item">
    <a class="nav-link" href="/bookings">
        📅 Bookings
    </a>
</li>





<% if(isHost){ %>

<li class="nav-item">

    <a
        class="nav-link"
        href="/dashboard">

        <i class="fa-solid fa-chart-line me-1"></i>
        Dashboard

    </a>

</li>

<% } %>

</div>

      <div class="navbar-nav ms-auto align-items-center">
        <form class="d-flex me-3" role="search" method="GET" action="/listings">
          <input
class="form-control me-2"
type="search"
name="search"
placeholder="Search destinations"
value="<%= typeof search !== 'undefined' ? search : '' %>">
          <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      

      
        
        <a class="nav-link" href="/listings/new">
    <i class="fa-solid fa-house-circle-plus me-1"></i>
    Become a Host
</a>

<li class="nav-item dropdown">

    <a
        class="nav-link dropdown-toggle position-relative"
        href="#"
        id="notificationDropdown"
        role="button"
        data-bs-toggle="dropdown"
        aria-expanded="false">

        <i class="fa-solid fa-bell"></i>

        <% if(unreadCount > 0){ %>

            <span
                class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">

                <%= unreadCount %>

            </span>

        <% } %>

    </a>

    <ul
    class="dropdown-menu dropdown-menu-end shadow"
    aria-labelledby="notificationDropdown"
    style="
        width:400px;
        max-height:420px;
        overflow-y:auto;
        overflow-x:hidden;
    ">
        <li>
            <h6 class="dropdown-header">
                🔔 Notifications
            </h6>
        </li>

        <% if(latestNotifications.length === 0){ %>

            <li>

                <span class="dropdown-item-text text-muted">
                    No notifications yet.
                </span>

            </li>

        <% } else { %>

            <% latestNotifications.forEach(notification => { %>

                <li>

                   <a
    class="dropdown-item py-3"
    style="white-space: normal;"
    href="/notifications">

                        <div
    class="fw-semibold"
    style="white-space: normal; word-break: break-word;">

    <%= notification.message %>

</div>

                        <small class="text-muted">

                            <%= notification.createdAt.toLocaleString("en-IN") %>

                        </small>

                    </a>

                </li>

            <% }) %>

        <% } %>

        <li>
            <hr class="dropdown-divider">
        </li>

        <li>

            <a
                class="dropdown-item text-center fw-bold"
                href="/notifications">

                View All Notifications →

            </a>

        </li>

    </ul>

</li>


        <% if(!currUser){ %>
        <a class="nav-link "  href="/signup"><b>Signup</b></a>
        <a class="nav-link" href="/login"><b>Login</b></a>
        <% } %> 
        <% if(currUser){ %>

<li class="nav-item dropdown me-3">

    <a
        class="nav-link dropdown-toggle account-menu"
        href="#"
        id="accountDropdown"
        role="button"
        data-bs-toggle="dropdown"
        aria-expanded="false">

        <i class="fa-solid fa-user me-1"></i>
        Account

    </a>

    <ul
        class="dropdown-menu dropdown-menu-end shadow"
        aria-labelledby="accountDropdown">

        <li>

            <a class="dropdown-item" href="/profile">

                <i class="fa-solid fa-user me-2"></i>
                My Profile

            </a>

        </li>

        <li><hr class="dropdown-divider"></li>

        <li>

            <a class="dropdown-item text-danger" href="/logout">

                <i class="fa-solid fa-right-from-bracket me-2"></i>
                Logout

            </a>

        </li>

    </ul>

</li>

<% } %>
