  }

  .search-inp{
    width:220px;
    border-radius:25px;
    padding:0.5rem 1rem;
    font-size:0.95rem;
}
</style>

<nav class="navbar navbar-expand-md bg-light border-bottom sticky-top">
  <div class="container-fluid">
