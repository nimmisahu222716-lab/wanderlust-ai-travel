<% layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <br/><br/>
    <div class="mb-5">

    <h2 class="fw-bold">

        <i class="fa-solid fa-plus-circle text-primary me-2"></i>

        Create a New Listing

    </h2>

    <p class="text-muted mb-0">

        Fill in the details below to publish your property.

    </p>

</div>
    <form 
      method = "POST" 
      action = "/listings" 
      novalidate 
      class="needs-validation" 
      enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input 
                id="title"
                name = "listing[title]" 
                placeholder = "Add a catchy title" 
                type="text" 
                class="form-control"
                required
            />
            <div class="valid-feedback">Title looks good</div>
        </div>
        
        <div class="mb-3">
    <label for="description" class="form-label">
        Description
    </label>

    <textarea
        id="description"
        name="listing[description]"
        placeholder="Enter description"
        class="form-control"
        rows="6"
        required></textarea>

    <div class="mt-3">
    <label for="tone" class="form-label fw-semibold">

    <i class="fa-solid fa-wand-magic-sparkles text-primary me-2"></i>

    AI Writing Style

</label>

    <select
        id="tone"
        class="form-select">

        <option value="Professional" selected>
            Professional
        </option>

        <option value="Luxury">
            Luxury Stay
        </option>

        <option value="Romantic">
            Romantic Getaway
        </option>

        <option value="Family">
            Family Friendly
        </option>

        <option value="Adventure">
            Adventure
        </option>

        <option value="Budget">
            Budget Stay
        </option>

        <option value="Relaxing">
            Relaxing Vacation
        </option>

        <option value="Business">
            Business Travel
        </option>

        <option value="Cozy">
            Cozy Cottage
        </option>

        <option value="Nature">
            Nature Escape
        </option>

    </select>
</div>
   <div class="ai-actions mt-3">

    <button
        type="button"
        id="generateAI"
        class="btn ai-action-btn">

        <i class="fa-solid fa-wand-magic-sparkles me-2"></i>

        Generate

    </button>

    <button
        type="button"
        id="improveAI"
        class="btn ai-action-btn">

        <i class="fa-solid fa-pen-to-square me-2"></i>

        Improve

    </button>

    <button
        type="button"
        id="regenerateAI"
        class="btn ai-action-btn">

        <i class="fa-solid fa-rotate-right me-2"></i>

        Regenerate

    </button>

</div>

    <small
        id="aiStatus"
        class="text-muted mt-2 d-block">
    </small>

    <div class="invalid-feedback">
        Please enter a short description
    </div>

</div>
        
       <div class="mb-3">
         <label for="image" class="form-label fw-semibold">

    <i class="fa-solid fa-image text-success me-2"></i>

    Upload Listing Image

</label>
         <input 
            name = "listing[image]" 
            type = "file" 
            class="form-control"/>
       </div>

       <div class="mb-3">
    <label for="category" class="form-label fw-semibold">

    <i class="fa-solid fa-layer-group text-warning me-2"></i>

    Category

</label>

    <select
        class="form-select"
        id="category"
        name="listing[category]"
        required
    >
        <option value="">Select Category</option>

        <option value="Trending">Trending</option>
        <option value="Rooms">Rooms</option>
        <option value="Iconic Cities">Iconic Cities</option>
        <option value="Mountains">Mountains</option>
        <option value="Castles">Castles</option>
        <option value="Amazing Pools">Amazing Pools</option>
        <option value="Camping">Camping</option>
        <option value="Farms">Farms</option>
        <option value="Arctic">Arctic</option>
        <option value="Domes">Domes</option>
        <option value="Boats">Boats</option>
        <option value="Beach">Beach</option>
        <option value="Desert">Desert</option>
        <option value="Snow">Snow</option>
    </select>
</div>
        
       <div class="row">

    <div class="mb-3 col-md-4">

        <label for="price" class="form-label">
            <i class="fa-solid fa-indian-rupee-sign text-success me-2"></i>

Price per Night
        </label>

        <input
            name="listing[price]"
            placeholder="4500"
            class="form-control"
            required>

        <div class="invalid-feedback">
            Price should be valid
        </div>

    </div>

    <div class="mb-3 col-md-4">

        <label for="maxGuests" class="form-label">
           <i class="fa-solid fa-user-group text-primary me-2"></i>

Maximum Guests
        </label>

        <input
            type="number"
            id="maxGuests"
            name="listing[maxGuests]"
            class="form-control"
            min="1"
            max="20"
            value="4"
            required>

        <div class="invalid-feedback">
            Enter maximum guests.
        </div>

    </div>

    <div class="mb-3 col-md-4">

        <label for="country" class="form-label">
            <i class="fa-solid fa-earth-asia text-success me-2"></i>

Country
        </label>

        <input
            id="country"
            name="listing[country]"
            placeholder="India"
            type="text"
            class="form-control"
            required>

        <div class="invalid-feedback">
            Country name should be valid
        </div>

    </div>

</div>


<div class="mb-3 form-check">

    <input
        class="form-check-input"
        type="checkbox"
        id="isAvailable"
        name="listing[isAvailable]"
        checked>

    <label
        class="form-check-label"
        for="isAvailable">

        Available for Booking

    </label>

</div>
        
        
        <div class="mb-3">
            <label for="location" class="form-label fw-semibold">

    <i class="fa-solid fa-location-dot text-danger me-2"></i>

    Location

</label>
            <input 
            id="location"
            name = "listing[location]" 
            placeholder = "Jaipur, Rajasthan" 
            type="text"
            class="form-control"
            required/>
            <div class="invalid-feedback">Location should be valid</div>
        </div>
        
        
        <button class="btn btn-dark add-btn mt-4 px-5 py-2 rounded-pill">

    <i class="fa-solid fa-circle-plus me-2"></i>

    Create Listing

</button>
      
    </form>
    </div>
</div>

<script src="/js/ai.js"></script>

