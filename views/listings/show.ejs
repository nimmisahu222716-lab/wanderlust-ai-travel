<% layout("/layouts/boilerplate")%>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing)%>;
    
</script>
<div class="row mt-4">

    <div class="col-lg-8 offset-lg-2 d-flex justify-content-between align-items-center mb-3">

        <div>

            <h2 class="fw-bold mb-1">
                <%= listing.title %>
            </h2>

            <small class="text-muted">

                <i class="fa-solid fa-location-dot text-danger"></i>

                <%= listing.location %>, <%= listing.country %>

            </small>

        </div>

    <% if(currUser){ %>

        <form action="/wishlist/<%= listing._id %>" method="POST">

            <button
                class="btn border-0 bg-transparent fs-2"
                title="Add to Wishlist">

                <% if(isWishlisted){ %>

<i class="fa-solid fa-heart text-danger"></i>

<% } else { %>

<i class="fa-regular fa-heart"></i>

<% } %>

            </button>

        </form>

    <% } %>

</div>
    <div class="card col-lg-8 offset-lg-2 show-card listing-card">
        <img 
            src="<%= listing.image.url %>" 
           class="card-img-top show-img img-fluid"
            alt="listing_image"
            />
        <div class="card-body">
           <div class="card mb-4 border-0 shadow-sm host-card">

    <div class="card-body d-flex align-items-center">

        <% if(listing.owner.image && listing.owner.image.url){ %>

            <img
                src="<%= listing.owner.image.url %>"
                class="rounded-circle me-3"
                width="60"
                height="60"
                style="object-fit: cover;">
<% } else { %>

<div
    class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-3"
    style="width:60px; height:60px;">

    <i class="fa-solid fa-user text-white fs-4"></i>

</div>

<% } %>

        <div>

            <small class="text-muted">
                Hosted by
            </small>

            <h5 class="mb-0">

                <a
                    href="/hosts/<%= listing.owner._id %>"
                    class="text-decoration-none text-dark">

                    <%= listing.owner.name || listing.owner.username %>

                </a>

            </h5>

        </div>

    </div>

</div>
            <p class="card-text"><%= listing.description%></p>
            <p class="card-text">
    <i class="fa-solid fa-indian-rupee-sign text-success"></i>

₹<%= listing.price.toLocaleString("en-IN") %>

<span class="text-muted">/ night</span>
</p>

<p class="card-text">
    <i class="fa-solid fa-user-group text-primary"></i>

Maximum Guests:
    <strong><%= listing.maxGuests %></strong>
</p>

<p class="card-text">

    <% if(listing.isAvailable){ %>

       <i class="fa-solid fa-circle-check text-success"></i> <strong>Available for Booking</strong>

    <% } else { %>

        <i class="fa-solid fa-circle-xmark text-danger"></i> <strong>Currently Unavailable</strong>

    <% } %>

    <% if(currUser && listing.owner._id.equals(currUser._id)){ %>

        <br>
        <small class="text-muted">
            You can change this from the Edit Listing page.
        </small>

    <% } %>

</p>

           
        </div>
    </div>

    
    <br/>

<!-- Booking Form (Only for logged-in users who are NOT the owner AND listing is available) -->

<% if(currUser && !listing.owner._id.equals(currUser._id) && listing.isAvailable){ %>

<div class="col-lg-8 offset-lg-2 mb-4">

    <div class="card shadow-sm booking-card">

        <div class="card-body">

            <h4 class="mb-3">
                <i class="fa-solid fa-calendar-days text-danger me-2"></i>

Reserve this stay
            </h4>

            <form
                action="/bookings/<%= listing._id %>"
                method="POST">

                <div class="mb-3">

                    <label class="form-label">
                        Check-in
                    </label>

                   <input
    type="date"
    id="checkIn"
    name="checkIn"
    class="form-control"
    required>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Check-out
                    </label>

                    <input
    type="date"
    id="checkOut"
    name="checkOut"
    class="form-control"
    required>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Guests
                    </label>

                    <input
                        type="number"
                        name="guests"
                        class="form-control"
                        value="1"
                        min="1"
                        required>

                </div>

                <hr>

<div id="bookingSummary">

    <p class="mb-1">
        💰 ₹<%= listing.price %> ×
        <span id="totalNights">0</span> night(s)
    </p>

    <h5>
        Total:
        ₹<span id="totalPrice">0</span>
    </h5>

</div>

                <button
    type="submit"
    class="btn btn-danger w-100 rounded-pill py-2">

    Reserve Now

</button>
            </form>

        </div>

    </div>

</div>

<% } %>


<!-- Show this when property is NOT available -->

<% if(currUser && !listing.owner._id.equals(currUser._id) && !listing.isAvailable){ %>

<div class="col-lg-8 offset-lg-2 mb-4">

    <div class="alert alert-warning">

        <h5>🔴 Booking Unavailable</h5>

        <p class="mb-0">
            This property is currently not accepting bookings.
        </p>

    </div>

</div>

<% } %>


<!-- Edit/Delete Buttons (Only Owner) -->
<% if(currUser && listing.owner._id.equals(currUser._id)) { %>

<div class="col-lg-8 offset-lg-2 mb-4">

    <div class="d-flex gap-3">

        <a
            href="/listings/<%= listing._id %>/edit"
            class="btn edit-btn rounded-pill px-4 py-2">

            <i class="fa-solid fa-pen me-2"></i>
            Edit

        </a>

        <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=DELETE"
            class="m-0">

            <button
                class="btn btn-dark rounded-pill px-4 py-2">

                <i class="fa-solid fa-trash me-2"></i>
                Delete

            </button>

        </form>

    </div>

</div>

<% } %>
  
  
   <div class="col-lg-8 offset-lg-2 mb-3">
    
    <% if(currUser) { %>
        <hr />
    <h4 class="fw-bold">

<i class="fa-solid fa-star text-warning"></i>

Leave a Review

</h4>
    <form 
        action="/listings/<%= listing.id%>/reviews" 
        method="POST" 
        novalidate 
        class="needs-validation">
        
        <div class="mb-3 mt-3">
            <label for="rating" class="form-label">Rating</label>
        <fieldset class="starability-slot">
            
            <input 
               type="radio" 
               id="no-rate" 
               class="input-no-rate" 
               name="review[rating]" 
               value="1" 
               checked 
               aria-label="No rating." 
            />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
        </div>

        <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea 
                id="comment" 
                name="review[comment]" 
                cols="30" rows="5" 
                class="form-control"
                required></textarea>
            <div class="invalid-feedback">
                please add some comment for review
            </div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr />
    <%}%>

    
     <% if(listing.reviews.length>0) {%>
    <div class="row">
        <h4 class="fw-bold mb-4">

<i class="fa-solid fa-comments text-primary"></i>

Guest Reviews

</h4>
     <% for(review of listing.reviews){%>
        <div class="col-lg-6 mb-4">

    <div class="card review-card h-100">
            <div class="card-body">
                <h5 class="card-title">@<%= review.author.username %></h5>
                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                <p class="card-text"><%= review.comment %></p>
            </div>
            <form class="mb-3" method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
            </form>
            </div>

</div>

        </div>
     <%}%>
    </div>
    <%}%>
    
   </div>
   <div class="col-lg-8 offset-lg-2">
        <h3 class="fw-bold mb-3">

<i class="fa-solid fa-location-dot text-danger"></i>

Where you'll be

</h3>
        <div id="map"></div>
    </div>
</div>

<script>

const today = new Date().toISOString().split("T")[0];

const checkIn = document.getElementById("checkIn");
const checkOut = document.getElementById("checkOut");

const totalNights = document.getElementById("totalNights");
const totalPrice = document.getElementById("totalPrice");

function updateBookingSummary() {

    if (!checkIn.value || !checkOut.value) {

        totalNights.textContent = 0;
        totalPrice.textContent = 0;

        return;
    }

    const start = new Date(checkIn.value);
    const end = new Date(checkOut.value);

    const oneDay = 1000 * 60 * 60 * 24;

    const nights = Math.ceil((end - start) / oneDay);

    if (nights <= 0) {

        totalNights.textContent = 0;
        totalPrice.textContent = 0;

        return;
    }

    totalNights.textContent = nights;

    totalPrice.textContent =
        (nights * listing.price).toLocaleString("en-IN");

}

if (checkIn && checkOut) {

    checkIn.min = today;

    checkOut.min = today;

    checkIn.addEventListener("change", () => {

        checkOut.min = checkIn.value;

        if (checkOut.value < checkIn.value) {
            checkOut.value = "";
        }

    });

    checkIn.addEventListener(
    "change",
    updateBookingSummary
);

checkOut.addEventListener(
    "change",
    updateBookingSummary
);

}

</script>

<script src="/js/map.js"></script>
