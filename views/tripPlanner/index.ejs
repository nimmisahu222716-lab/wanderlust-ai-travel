<% layout("/layouts/boilerplate") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body p-4">

                    <h2 class="mb-2">
                        🧳 AI Travel Planner
                    </h2>

                    <p class="text-muted mb-4">
                        Create personalized travel itineraries with Gemini AI.
                    </p>

                    <form id="tripPlannerForm">

                        <!-- Destination -->
                        <div class="mb-3">
                            <label class="form-label">Destination</label>

                            <input
                                type="text"
                                id="destination"
                                class="form-control"
                                placeholder="Goa"
                                required>
                        </div>

                        <!-- Travel Month -->
                        <div class="mb-3">
                            <label class="form-label">Travel Month</label>

                            <select id="month" class="form-select">

                                <option>January</option>
                                <option>February</option>
                                <option>March</option>
                                <option>April</option>
                                <option>May</option>
                                <option>June</option>
                                <option>July</option>
                                <option>August</option>
                                <option>September</option>
                                <option>October</option>
                                <option>November</option>
                                <option selected>December</option>

                            </select>
                        </div>

                        <!-- Duration -->
                        <div class="mb-3">
                            <label class="form-label">Duration (Days)</label>

                            <input
                                type="number"
                                id="days"
                                class="form-control"
                                min="1"
                                max="30"
                                value="5">
                        </div>

                        <!-- Budget -->
                        <div class="mb-3">
                            <label class="form-label">Budget (₹)</label>

                            <input
                                type="number"
                                id="budget"
                                class="form-control"
                                placeholder="30000">
                        </div>

                        <!-- Travel Style -->
                        <div class="mb-3">
                            <label class="form-label">Travel Style</label>

                            <select id="style" class="form-select">

                                <option>Adventure</option>
                                <option>Luxury</option>
                                <option>Family</option>
                                <option>Romantic</option>
                                <option>Solo</option>
                                <option>Budget</option>
                                <option>Nature</option>
                                <option>Cultural</option>

                            </select>
                        </div>

                        <!-- Travelers -->
                        <div class="mb-4">
                            <label class="form-label">
                                Number of Travelers
                            </label>

                            <select id="travelers" class="form-select">

                                <option>1</option>
                                <option selected>2</option>
                                <option>3</option>
                                <option>4</option>
                                <option>5+</option>

                            </select>
                        </div>

                        <button
                            type="button"
                            id="generateTrip"
                            class="btn btn-dark w-100">

                            ✨ Generate Trip Plan

                        </button>

                    </form>

                    <div class="mt-4 text-end">

    <button
        id="downloadPDF"
        class="btn btn-outline-dark"
        style="display:none;">

        📄 Download Itinerary PDF

    </button>

</div>

<div id="tripResult" class="mt-3"></div>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script src="/js/tripPlanner.js"></script>