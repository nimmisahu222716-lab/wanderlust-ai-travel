<% layout("/layouts/boilerplate") %>

<div class="d-flex align-items-center mb-5">

    <i class="fa-solid fa-calendar-check text-primary fs-2 me-3"></i>

    <div>

        <h2 class="fw-bold mb-0">
            My Bookings
        </h2>

        <small class="text-muted">
            Manage your upcoming and past stays.
        </small>

    </div>

</div>

<% if(bookings.length === 0){ %>

    <div class="text-center py-5">

    <i class="fa-solid fa-calendar-xmark fa-5x text-secondary mb-4"></i>

    <h3>No bookings yet</h3>

    <p class="text-muted">

        Book your first stay and it will appear here.

    </p>

    <a
        href="/listings"
        class="btn btn-outline-dark rounded-pill px-4">

        Explore Listings

    </a>

</div>

<% } else { %>

<div class="row">

<% bookings.forEach(booking => { %>

<div class="col-md-6 mb-4">

    <div class="card shadow-sm booking-history-card">

        <img
            src="<%= booking.listing.image.url %>"
            class="card-img-top"
            style="height:250px; object-fit:cover;">

        <div class="card-body">

            <h5 class="fw-bold mb-3">

    <%= booking.listing.title %>

</h5>

            <p class="mb-2">

    <i class="fa-solid fa-calendar-days text-primary me-2"></i>

    <%= booking.checkIn.toDateString() %>

    <i class="fa-solid fa-arrow-right mx-2 text-muted"></i>

    <%= booking.checkOut.toDateString() %>

</p>

            <p class="mb-2">

    <i class="fa-solid fa-user-group text-success me-2"></i>

    <strong><%= booking.guests %></strong> Guest(s)

</p>

            <p class="fw-semibold">

    <i class="fa-solid fa-indian-rupee-sign text-success me-2"></i>

    ₹<%= booking.totalPrice.toLocaleString("en-IN") %>

</p>

            <p>

                <% if(booking.status === "Confirmed"){ %>

                   <span class="badge rounded-pill bg-success px-3 py-2">
                        Confirmed
                    </span>

                <% } else { %>

                    <span class="badge rounded-pill bg-danger px-3 py-2">
                        Cancelled
                    </span>

                <% } %>

            </p>
<div class="d-flex justify-content-between">

    <a
        href="/listings/<%= booking.listing._id %>"
        class="btn btn-dark">

        <i class="fa-solid fa-eye me-1"></i>

View

    </a>

    <% if(booking.status === "Confirmed"){ %>

        <form
            action="/bookings/cancel/<%= booking._id %>"
            method="POST">

            <button
                class="btn btn-outline-danger">

                <i class="fa-solid fa-ban me-1"></i>

Cancel

            </button>

        </form>

    <% } %>

</div>
        </div>

    </div>

</div>

<% }) %>

</div>

<% } %>