<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-7 col-xl-6">

            <div class="card shadow-lg border-0 profile-card">

                <div class="card-body p-5">

                    <div class="text-center">

                        <% if(user.image && user.image.url){ %>

                           <img
    src="<%= user.image.url %>"
    class="rounded-circle mb-3 profile-image"
    width="160"
    height="160"
    style="object-fit: cover;">

                        <% } else { %>

                           <img
    src="https://cdn-icons-png.flaticon.com/512/847/847969.png"
    class="rounded-circle mb-3 profile-image"
    width="160"
    height="160">
                        <% } %>

                        <h2 class="fw-bold mb-1">
    <%= user.name || "User" %>
</h2>

<p class="text-secondary mb-3">

    <i class="fa-solid fa-calendar-days text-danger me-2"></i>

    Member since

    <% if(user.createdAt){ %>

        <%= user.createdAt.toLocaleDateString("en-IN", {
            month: "long",
            year: "numeric"
        }) %>

    <% } else { %>

        Recently

    <% } %>

</p>

                    </div>

                    <hr>

                    <div class="row">

                        <div class="row">

    <div class="col-md-6 mb-4">

      <h6 class="section-title">

<i class="fa-solid fa-envelope text-primary me-2"></i>

Email

</h6>

       <div class="about-box"> <p class="text-muted">
            <%= user.email %>
        </p>
    </div>
       

    </div>

    <div class="col-md-6 mb-4">

        <h6 class="section-title">

<i class="fa-solid fa-phone text-success me-2"></i>

Phone

</h6>

        <p class="text-muted">
            <%= user.phone || "Not Added" %>
        </p>

    </div>

    <div class="col-md-12 mb-4">

        <h6 class="section-title">

<i class="fa-solid fa-location-dot text-danger me-2"></i>

Location

</h6>

        <p class="text-muted">
            <%= user.location || "Not Added" %>
        </p>

    </div>

</div>
                       <hr>

<h4 class="fw-bold text-center mb-4">

    <i class="fa-solid fa-chart-column text-primary me-2"></i>

    Profile Statistics

</h4>

<div class="row text-center">

    <div class="col-md-4 mb-3">

       <div class="card shadow-sm border-0 profile-stat">

            <div class="card-body">

                <h2 class="fw-bold text-danger">
                    <%= wishlistCount %>
                </h2>

                <p class="text-muted mb-0">
                    <i class="fa-solid fa-heart text-danger fs-3"></i>
                    <h2>...</h2>

<p>Wishlist</p>
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-4 mb-3">

       <div class="card shadow-sm border-0 profile-stat">

            <div class="card-body">

                <h2 class="fw-bold text-primary">
                    <%= bookingCount %>
                </h2>

                <p class="text-muted mb-0">
                    <i class="fa-solid fa-calendar-check text-primary fs-3"></i>
                    <h2>...</h2>

<p>Booking</p>
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-4 mb-3">

        <div class="card shadow-sm border-0 profile-stat">

            <div class="card-body">

                <h2 class="fw-bold text-success">
                    <%= listingCount %>
                </h2>

                <p class="text-muted mb-0">
                    <i class="fa-solid fa-house text-success fs-3"></i>
                    <h2>...</h2>

<p>Listing</p>
                </p>

            </div>

        </div>

    </div>

</div>

<hr>

                    </div>

                    <div class="mb-4">

                        <h6 class="section-title">

<i class="fa-solid fa-user text-warning me-2"></i>

About

</h6>

                        <p class="text-muted">

                            <%= user.bio || "No bio added yet." %>

                        </p>

                    </div>

                    <div class="text-center">

                        <a
                            href="/profile/edit"
                            class="btn btn-dark rounded-pill px-5 py-2">

                            Edit Profile

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>